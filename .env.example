
# Optional token for the management API on port 8580 (empty = auth disabled).
# Clients send it as "X-API-Token: <token>" or "Authorization: Bearer <token>".
API_TOKEN=

# Bind address for publishing port 8580. Default 127.0.0.1 (loopback only).
# Set to 0.0.0.0 to reach the UI from the LAN / embed it in Home Assistant —
# but ONLY together with API_TOKEN.
UI_BIND=127.0.0.1

# How speaker identity reaches the transcript consumer: prefix | field | both.
# prefix = "Krzysztof: ..." in the text; field = clean text + "speaker" field
# in the Wyoming Transcript event; both = both. Changeable at runtime in the UI.
SPEAKER_TEXT_MODE=prefix

# Speaker identification (named speakers via ECAPA enrollment)
SPEAKER_ID_ENABLED=false
SPEAKER_ENROLLMENT_DIR=speakers
SPEAKER_MATCH_THRESHOLD=0.35
SPEAKER_MODEL=speechbrain/spkrec-ecapa-voxceleb

# whisper.cpp server doing the actual speech-to-text.
WHISPERCPP_URL=http://whispercpp:4050

# Optional whisper initial prompt: bias decoding toward household vocabulary
# (assistant name, people, rooms, devices). Nouns/proper names only — example
# commands get echoed back as hallucinations on noisy audio.
# WHISPER_INITIAL_PROMPT=Agata (asystentka domowa), Krzysztof, salon, telewizor.
# Transcript label for unenrolled speakers (localize to taste, e.g. Mówca).
SPEAKER_LABEL=Speaker
